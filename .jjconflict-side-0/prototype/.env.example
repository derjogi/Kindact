# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:pass@localhost:5432/kindact?schema=public"

# ─── AI Provider (OpenRouter) ────────────────────────────────────────────────
# Get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-v1-..."

# Default model used when a slot doesn't specify one (free tier)
OPENROUTER_DEFAULT_MODEL="qwen/qwen3-next-80b-a3b-instruct:free"

# ─── AI Slot Overrides (optional) ────────────────────────────────────────────
# Format: AI_<SLOT>_MODEL, AI_<SLOT>_PROMPT, AI_<SLOT>_MAX_TOKENS
#
# AI_DELIBERATION_SUMMARY_MODEL="nvidia/nemotron-3-super:free"
# AI_DELIBERATION_SUMMARY_PROMPT="Summarize the following deliberation..."
# AI_DELIBERATION_SUMMARY_MAX_TOKENS=2048
#
# AI_ISSUE_IMPROVER_MODEL="nvidia/nemotron-3-super:free"
# AI_ISSUE_IMPROVER_PROMPT="Suggest improvements to this issue..."
#
# AI_TOPIC_PROPOSER_MODEL="qwen/qwen3-next-80b-a3b-instruct:free"
# AI_TOPIC_PROPOSER_MAX_TOKENS=256
#
# AI_SIMILARITY_DETECTOR_MODEL="qwen/qwen3-next-80b-a3b-instruct:free"
# AI_SIMILARITY_DETECTOR_MAX_TOKENS=512
