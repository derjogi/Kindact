generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── 001: Core Event Ledger ─────────────────────────────────────────────────

model LedgerEvent {
  id          String   @id @default(uuid())
  sequence    BigInt   @default(autoincrement()) @unique
  actor       String   // user ID who triggered the event
  objectType  String   @map("object_type")  // e.g. "issue", "vote", "claim"
  objectId    String   @map("object_id")
  action      String   // e.g. "created", "updated", "state_changed"
  payloadHash String   @map("payload_hash") // SHA-256 of payload blob
  prevHash    String?  @map("prev_hash")    // hash of previous event in stream
  eventHash   String   @map("event_hash")   // hash of this event's canonical form
  metadata    Json?    // non-sensitive metadata (IP excluded)
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("ledger_events")
  @@index([objectType, objectId])
  @@index([actor])
  @@index([createdAt])
}

model ContentBlob {
  id        String   @id @default(uuid())
  hash      String   @unique // SHA-256 content hash
  bucket    String   @default("local") // storage backend identifier
  key       String   // object key / file path
  mimeType  String?  @map("mime_type")
  sizeBytes BigInt?  @map("size_bytes")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("content_blobs")
}

// Future Phase 2 anchor batches (table exists now, unused at MVP)
model AnchorBatch {
  id           String    @id @default(uuid())
  startEventId String    @map("start_event_id")
  endEventId   String    @map("end_event_id")
  batchHash    String?   @map("batch_hash")
  chain        String?
  txHash       String?   @map("tx_hash")
  anchoredAt   DateTime? @map("anchored_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@map("anchor_batches")
}

// ─── 002: Wallet Auth ───────────────────────────────────────────────────────

model User {
  id          String   @id @default(uuid())
  displayName String?  @map("display_name")
  avatar      String?
  bio         String?
  tags        String[] @default([]) // profile tags for auto-stakeholder matching
  humanId     String?  @unique @map("human_id") // from human verification
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  wallets              WalletLink[]
  sessions             Session[]
  identityProviderLinks IdentityProviderLink[]
  issueAliases         IssueAlias[]
  votes                VoteRecord[]
  claims               Claim[]
  notifications        Notification[]
  subscriptions        IssueSubscription[]
  notificationPrefs    NotificationPreference[]
  tokenAccount         TokenAccount?
  riskSignals          RiskSignal[]
  restrictions         Restriction[]
  appeals              Appeal[]

  @@map("users")
}

model WalletLink {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  address   String    @unique // lowercase checksummed wallet address
  linkedAt  DateTime  @default(now()) @map("linked_at")
  unlinkedAt DateTime? @map("unlinked_at")

  user User @relation(fields: [userId], references: [id])

  @@map("wallet_links")
}

model Session {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("sessions")
  @@index([token])
}

// ─── 003: Human Verification ────────────────────────────────────────────────

model IdentityProviderLink {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  provider    String   // e.g. "gitcoin-passport"
  attestation Json?    // provider-specific attestation data
  score       Float?   // provider trust score
  connectedAt DateTime @default(now()) @map("connected_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, provider])
  @@map("identity_provider_links")
}

// ─── 004: Issue Intake ──────────────────────────────────────────────────────

enum IssueStatus {
  draft
  deliberating
  vote_ready     @map("vote-ready")
  adopted
  implementing
  completed
  archived
}

enum IssueScope {
  local
  national
  global
}

model Issue {
  id          String      @id @default(uuid())
  title       String
  summary     String
  description String
  status      IssueStatus @default(draft)
  scope       IssueScope
  tags        String[]    @default([])
  creatorId   String      @map("creator_id")
  participants Int        @default(0)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  rewardIntent  RewardIntent?
  revisions     IssueRevision[]
  comments      Comment[]
  arguments     ArgumentNode[]
  proposalDoc   ProposalDocument?
  metrics       MetricAssessment[]
  boundaries    BoundaryAssessment[]
  stakeClaims   StakeClaim[]
  eligibilityQuiz EligibilityQuiz?
  voteRecords   VoteRecord[]
  decisionState DecisionState?
  workPackages  WorkPackage[]
  issueAliases  IssueAlias[]
  subscriptions IssueSubscription[]
  aiSummary     AISummary?

  @@map("issues")
  @@index([status])
  @@index([scope])
  @@index([createdAt])
}

model IssueRevision {
  id        String   @id @default(uuid())
  issueId   String   @map("issue_id")
  title     String
  summary   String
  description String
  authorId  String   @map("author_id")
  createdAt DateTime @default(now()) @map("created_at")

  issue Issue @relation(fields: [issueId], references: [id])

  @@map("issue_revisions")
}

model RewardIntent {
  id       String  @id @default(uuid())
  issueId  String  @unique @map("issue_id")
  amount   String  // e.g. "500 $CC per milestone"
  locked   Boolean @default(false)

  issue Issue @relation(fields: [issueId], references: [id])

  @@map("reward_intents")
}

// ─── 005: Deliberation Workspace ────────────────────────────────────────────

model Comment {
  id        String   @id @default(uuid())
  issueId   String   @map("issue_id")
  authorId  String   @map("author_id")
  text      String
  parentId  String?  @map("parent_id")
  upvotes   Int      @default(0)
  downvotes Int      @default(0)
  stance    String?  // "pro" | "con" | null
  createdAt DateTime @default(now()) @map("created_at")

  issue  Issue    @relation(fields: [issueId], references: [id])
  parent Comment? @relation("CommentReplies", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentReplies")

  @@map("comments")
  @@index([issueId])
}

model ArgumentNode {
  id        String   @id @default(uuid())
  issueId   String   @map("issue_id")
  authorId  String   @map("author_id")
  text      String
  type      String   // "pro" | "con"
  parentId  String?  @map("parent_id")
  createdAt DateTime @default(now()) @map("created_at")

  issue  Issue         @relation(fields: [issueId], references: [id])
  parent ArgumentNode? @relation("ArgumentTree", fields: [parentId], references: [id])
  children ArgumentNode[] @relation("ArgumentTree")

  @@map("argument_nodes")
  @@index([issueId])
}

model IssueAlias {
  id      String @id @default(uuid())
  issueId String @map("issue_id")
  userId  String @map("user_id")
  alias   String
  emoji   String

  issue Issue @relation(fields: [issueId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([issueId, userId])
  @@map("issue_aliases")
}

model ProposalDocument {
  id        String   @id @default(uuid())
  issueId   String   @unique @map("issue_id")
  body      String   @default("")
  updatedAt DateTime @updatedAt @map("updated_at")

  issue     Issue              @relation(fields: [issueId], references: [id])
  revisions ProposalRevision[]

  @@map("proposal_documents")
}

model ProposalRevision {
  id         String   @id @default(uuid())
  proposalId String   @map("proposal_id")
  body       String
  authorId   String   @map("author_id")
  createdAt  DateTime @default(now()) @map("created_at")

  proposal ProposalDocument @relation(fields: [proposalId], references: [id])

  @@map("proposal_revisions")
}

// ─── 006: AI Assistance ─────────────────────────────────────────────────────

model AISummary {
  id            String   @id @default(uuid())
  issueId       String   @unique @map("issue_id")
  content       String
  modelVersion  String   @map("model_version")
  promptVersion String   @map("prompt_version")
  sourceRefs    String[] @default([]) @map("source_refs") // comment/argument IDs cited
  generatedAt   DateTime @default(now()) @map("generated_at")

  issue Issue @relation(fields: [issueId], references: [id])

  @@map("ai_summaries")
}

// ─── 007: Metrics & Eligibility ─────────────────────────────────────────────

model MetricAssessment {
  id         String   @id @default(uuid())
  issueId    String   @map("issue_id")
  dimension  String   // "cost", "time"
  value      String
  confidence String   // "low", "medium", "high"
  sourceType String   @map("source_type") // "creator", "expert", "user"
  authorId   String   @map("author_id")
  createdAt  DateTime @default(now()) @map("created_at")

  issue Issue @relation(fields: [issueId], references: [id])

  @@map("metric_assessments")
  @@index([issueId])
}

model BoundaryAssessment {
  id         String   @id @default(uuid())
  issueId    String   @map("issue_id")
  label      String   // e.g. "Freshwater", "Climate", "Health"
  icon       String   // emoji icon
  direction  String   // "improve", "regress", "neutral"
  delta      String   // e.g. "+8%", "-2%"
  confidence String   // "low", "medium", "high"
  authorId   String   @map("author_id")
  createdAt  DateTime @default(now()) @map("created_at")

  issue Issue @relation(fields: [issueId], references: [id])

  @@map("boundary_assessments")
  @@index([issueId])
}

model StakeClaim {
  id        String   @id @default(uuid())
  issueId   String   @map("issue_id")
  userId    String   @map("user_id")
  status    String   @default("pending") // "pending", "accepted", "rejected"
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")

  issue Issue @relation(fields: [issueId], references: [id])

  @@unique([issueId, userId])
  @@map("stake_claims")
}

model EligibilityQuiz {
  id        String   @id @default(uuid())
  issueId   String   @unique @map("issue_id")
  questions Json     // array of { question, type, options, correctAnswer }
  active    Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  issue    Issue          @relation(fields: [issueId], references: [id])
  attempts QuizAttempt[]

  @@map("eligibility_quizzes")
}

model QuizAttempt {
  id       String   @id @default(uuid())
  quizId   String   @map("quiz_id")
  userId   String   @map("user_id")
  answers  Json
  passed   Boolean
  takenAt  DateTime @default(now()) @map("taken_at")

  quiz EligibilityQuiz @relation(fields: [quizId], references: [id])

  @@map("quiz_attempts")
  @@index([quizId, userId])
}

// ─── 008: Voting Engine ─────────────────────────────────────────────────────

model VoteRecord {
  id        String   @id @default(uuid())
  issueId   String   @map("issue_id")
  userId    String   @map("user_id")
  vote      String   // "approve" | "reject"
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  issue Issue @relation(fields: [issueId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([issueId, userId])
  @@map("vote_records")
}

model DecisionState {
  id              String    @id @default(uuid())
  issueId         String    @unique @map("issue_id")
  state           String    @default("open") // "open", "adopted", "paused", "reversed"
  approveCount    Int       @default(0) @map("approve_count")
  rejectCount     Int       @default(0) @map("reject_count")
  threshold       Float     @default(0.8) // 80% default
  quorum          Int       @default(5)
  observationStart DateTime? @map("observation_start")
  observationDays  Int       @default(7) @map("observation_days")
  adoptedAt       DateTime? @map("adopted_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  issue Issue @relation(fields: [issueId], references: [id])

  @@map("decision_states")
}

// ─── 009: Work Reports & Evidence ───────────────────────────────────────────

model WorkPackage {
  id          String   @id @default(uuid())
  issueId     String   @map("issue_id")
  title       String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  issue  Issue   @relation(fields: [issueId], references: [id])
  claims Claim[]

  @@map("work_packages")
  @@index([issueId])
}

model Claim {
  id            String   @id @default(uuid())
  workPackageId String   @map("work_package_id")
  implementerId String   @map("implementer_id")
  status        String   @default("active") // "active", "submitted", "verified", "rejected"
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  workPackage WorkPackage           @relation(fields: [workPackageId], references: [id])
  implementer User                  @relation(fields: [implementerId], references: [id])
  reports     ImplementationReport[]
  reviews     VerificationReview[]
  disputes    DisputeCase[]

  @@map("claims")
  @@index([workPackageId])
}

model ImplementationReport {
  id        String   @id @default(uuid())
  claimId   String   @map("claim_id")
  type      String   // "partial", "milestone", "final"
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  claim    Claim           @relation(fields: [claimId], references: [id])
  evidence EvidenceAsset[]

  @@map("implementation_reports")
}

model EvidenceAsset {
  id        String   @id @default(uuid())
  reportId  String   @map("report_id")
  blobHash  String   @map("blob_hash") // references ContentBlob.hash
  fileName  String?  @map("file_name")
  mimeType  String?  @map("mime_type")
  createdAt DateTime @default(now()) @map("created_at")

  report ImplementationReport @relation(fields: [reportId], references: [id])

  @@map("evidence_assets")
}

// ─── 010: Verification & Disputes ───────────────────────────────────────────

model VerificationReview {
  id        String   @id @default(uuid())
  claimId   String   @map("claim_id")
  reviewerId String  @map("reviewer_id")
  decision  String   // "approve", "reject", "request_changes"
  rationale String?
  createdAt DateTime @default(now()) @map("created_at")

  claim Claim @relation(fields: [claimId], references: [id])

  @@map("verification_reviews")
  @@index([claimId])
}

model DisputeCase {
  id           String    @id @default(uuid())
  claimId      String    @map("claim_id")
  challengerId String    @map("challenger_id")
  reason       String
  status       String    @default("open") // "open", "resolved_fraud", "resolved_clean", "dismissed"
  resolvedAt   DateTime? @map("resolved_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  claim Claim @relation(fields: [claimId], references: [id])

  @@map("dispute_cases")
}

// ─── 011: $CC Token Ledger ──────────────────────────────────────────────────

model TokenAccount {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  balance   Float    @default(0) // current demurrage-adjusted balance
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user       User          @relation(fields: [userId], references: [id])
  mintEvents MintEvent[]
  burnEvents BurnEvent[]

  @@map("token_accounts")
}

model MintEvent {
  id             String   @id @default(uuid())
  accountId      String   @map("account_id")
  amount         Float
  sourceType     String   @map("source_type") // "work_minting"
  sourceClaimId  String?  @map("source_claim_id")
  sourceReportId String?  @map("source_report_id")
  createdAt      DateTime @default(now()) @map("created_at")

  account TokenAccount @relation(fields: [accountId], references: [id])

  @@map("mint_events")
}

model BurnEvent {
  id        String   @id @default(uuid())
  accountId String   @map("account_id")
  amount    Float
  burnType  String   @map("burn_type") // "access_fee", "tx_fee"
  createdAt DateTime @default(now()) @map("created_at")

  account TokenAccount @relation(fields: [accountId], references: [id])

  @@map("burn_events")
}

model DemurrageCheckpoint {
  id         String   @id @default(uuid())
  decayIndex Float    @map("decay_index") // global decay multiplier
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("demurrage_checkpoints")
}

model MonetarySnapshot {
  id          String   @id @default(uuid())
  period      String   // e.g. "2026-03"
  totalSupply Float    @map("total_supply")
  totalMinted Float    @map("total_minted")
  totalBurned Float    @map("total_burned")
  decayIndex  Float    @map("decay_index")
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([period])
  @@map("monetary_snapshots")
}

// ─── 012: Fraud & Risk Engine ───────────────────────────────────────────────

model RiskSignal {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  signalType   String   @map("signal_type") // "issue_rate", "report_rate", "verification_fail_ratio", etc.
  confidence   Float
  triggerEvent String?  @map("trigger_event") // ledger event ID
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("risk_signals")
  @@index([userId])
}

model Restriction {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  type       String    // "throttle", "enhanced_review", "privilege_freeze", "payout_delay"
  reasonCode String    @map("reason_code")
  expiresAt  DateTime? @map("expires_at")
  liftedAt   DateTime? @map("lifted_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("restrictions")
  @@index([userId])
}

model Appeal {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  restrictionId String    @map("restriction_id")
  reason        String
  status        String    @default("pending") // "pending", "accepted", "rejected"
  resolvedAt    DateTime? @map("resolved_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("appeals")
}

// ─── 019: Notifications ─────────────────────────────────────────────────────

model IssueSubscription {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  issueId   String   @map("issue_id")
  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id])
  issue Issue @relation(fields: [issueId], references: [id])

  @@unique([userId, issueId])
  @@map("issue_subscriptions")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String   // "issue.state_changed", "vote.tally_shifted", etc.
  objectId  String?  @map("object_id")
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("notifications")
  @@index([userId, read])
}

model NotificationPreference {
  id        String  @id @default(uuid())
  userId    String  @map("user_id")
  eventType String  @map("event_type")
  enabled   Boolean @default(true)

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, eventType])
  @@map("notification_preferences")
}
